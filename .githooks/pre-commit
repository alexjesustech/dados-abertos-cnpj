#!/usr/bin/env bash
# ============================================================================
# .githooks/pre-commit — gitleaks: barra segredos em arquivos staged.
#
# @ai-generated by claude-code (Opus 4.8)
#
# Defesa em profundidade da custódia SOPS+age (GUARD-002). Complementa o
# pre-push (CI local). Ativado via core.hooksPath=.githooks.
# Fail-open: se o gitleaks não estiver instalado, avisa mas não trava o commit
# (evita induzir --no-verify habitual). Nunca use --no-verify silenciosamente.
# ============================================================================
set -uo pipefail

GL="$(command -v gitleaks 2>/dev/null || echo "$HOME/.local/bin/gitleaks")"

if [ ! -x "$GL" ]; then
  printf '\033[33m[gitleaks] binário ausente — commit liberado SEM scan de segredos. Reinstale em ~/.local/bin.\033[0m\n' >&2
  exit 0
fi

if ! "$GL" git --staged --redact --no-banner; then
  printf '\033[31m[gitleaks] possível SEGREDO nos arquivos staged — commit BLOQUEADO.\033[0m\n' >&2
  printf '  Falso positivo? Adicione um allowlist no .gitleaks.toml do repo. NÃO use --no-verify.\n' >&2
  exit 1
fi
exit 0
