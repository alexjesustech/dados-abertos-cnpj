#!/usr/bin/env bash
# pre-commit — duas defesas em profundidade:
#   1. branch-guard: barra commit direto em main/master (feature branch obrigatória).
#   2. gitleaks: barra segredos em arquivos staged (custódia SOPS+age, GUARD-002).
# Instalado em repos NOVOS via `git config --global init.templateDir`. Repos com
# core.hooksPath local (padrão CI-local "nous", .githooks/) recebem cópia própria com
# este mesmo corpo. Nunca use --no-verify silenciosamente.
set -uo pipefail

# === branch-guard (camada 3 do fluxo /branch — AGENTS.md § Fluxo de branch) ===
# Bloqueia commit direto em main/master. develop fica livre (é branch de trabalho em
# vários repos). Escape per-repo: `git config hooks.allowMainCommit true` (o meta-repo
# ~/projects está marcado assim — governança vai direto na main). Escape pontual:
# ALLOW_MAIN_COMMIT=1 git commit ...  Não aplica no commit inicial (HEAD unborn).
if [ "${ALLOW_MAIN_COMMIT:-0}" != "1" ] \
   && [ "$(git config --bool hooks.allowMainCommit 2>/dev/null)" != "true" ] \
   && git rev-parse --verify -q HEAD >/dev/null 2>&1; then
  __bg_branch="$(git symbolic-ref --short -q HEAD || echo '')"
  case "$__bg_branch" in
    main|master)
      printf '\033[31m✗ [branch-guard] commit direto em '\''%s'\'' BLOQUEADO.\033[0m\n' "$__bg_branch" >&2
      printf '  Crie uma feature branch: /branch <slug>  (ou git switch -c feature/<slug>)\n' >&2
      printf '  Exceção legítima? git config hooks.allowMainCommit true  (per-repo)\n' >&2
      printf '  ou pontual: ALLOW_MAIN_COMMIT=1 git commit ...   NÃO use --no-verify.\n' >&2
      exit 1
      ;;
  esac
fi
# === fim do branch-guard ===

# === gitleaks ===
GL="$(command -v gitleaks 2>/dev/null || echo "$HOME/.local/bin/gitleaks")"

if [ ! -x "$GL" ]; then
  printf '\033[33m[gitleaks] binário ausente — commit liberado SEM scan de segredos. Reinstale em ~/.local/bin.\033[0m\n' >&2
  exit 0
fi

if ! "$GL" git --staged --redact --no-banner; then
  printf '\033[31m[gitleaks] possível SEGREDO nos arquivos staged — commit BLOQUEADO.\033[0m\n' >&2
  printf '  Falso positivo? Adicione um allowlist no .gitleaks.toml do repo. NÃO use --no-verify.\n' >&2
  exit 1
fi
# === fim do gitleaks ===
exit 0
