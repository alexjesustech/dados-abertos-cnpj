# Configurações do Banco de Dados
DB_PATH=dados_cnpj.db

# Configurações de Extração
# Defina como true para excluir os arquivos .zip baixados após a extração
DELETE_ZIP_AFTER=false

# Fonte de Dados (WebDAV público do Nextcloud da RFB)
# Token do share público em arquivos.receitafederal.gov.br/index.php/s/<TOKEN>
# Padrão atual da RFB: gn672Ad4CF8N6TK. Se a RFB rotacionar, atualize aqui.
RFB_SHARE_TOKEN=gn672Ad4CF8N6TK

# Período YYYY-MM a baixar (deixe vazio para usar o mais recente disponível)
CNPJ_PERIOD=

# Configurações de Alertas e Notificações (Opcionais)
# Preencha para receber notificações no Discord e/ou Telegram
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
